# Copy this file to .env and fill in your values.
# Never commit .env to version control.

JOTFORM_API_KEY=your_api_key_here

# Web app password — anyone with this password can access the download UI
APP_PASSWORD=choose_a_strong_password_here

# Secret key for Flask session signing — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_secret_here
